{
  "name": "markdown-editor",
  "version": "1.0.1",
  "description": "极简Markdown编辑器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.armd.markdown-editor",
    "productName": "极简Markdown编辑器",
    "icon": "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["*.png", "*.ico"]
      },
      {
        "from": "preload.js",
        "to": "preload.js"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-v${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "极简Markdown编辑器",
      "artifactName": "${productName}-v${version}-setup.${ext}"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.0",
    "electron-packager": "^17.1.2"
  }
}
