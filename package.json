{
  "name": "markdown-editor",
  "version": "1.0.2",
  "description": "极简Markdown编辑器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "node scripts/sync-vendor.js",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.armd.markdown-editor",
    "productName": "极简Markdown编辑器",
    "icon": "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["*.png", "*.ico"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-v${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "极简Markdown编辑器",
      "artifactName": "${productName}-v${version}-setup.${ext}"
    }
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "11.11.1",
    "dompurify": "3.4.0",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "katex": "0.16.47",
    "marked": "12.0.0",
    "mermaid": "10.9.6"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
