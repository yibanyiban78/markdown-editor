{
  "name": "markdown-editor",
  "version": "1.0.0",
  "description": "极简Markdown编辑器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.armd.markdown-editor",
    "productName": "极简Markdown编辑器",
    "icon": "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.png",
      "artifactName": "${productName}-v${version}.${ext}"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.0",
    "electron-packager": "^17.1.2"
  }
}
